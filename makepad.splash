use mod.std.*
use mod.hub;
let RunItem = {
    on_run: nil,
    name: ""
    package_name: ""
    in_studio: true
}

let RunQuest = RunItem{
    on_run: fn(){
        hub.run(
            {"STUDIO": hub.studio_ip, "MAKEPAD": "vulkan"},
            "cargo", 
            [
                "run" "-p" "cargo-makepad" "--release" "--message-format=json" "--"
                "android" "--variant=quest" "--no-icon" "--small-fonts" "run" "-p" self.name "--release" "--message-format=json"
            ],
        )
    }
}

let RunAndroid = RunItem{
    on_run: fn(){
        hub.run(
            {"STUDIO": hub.studio_ip, "MAKEPAD": "vulkan"},
            "cargo", 
            [
                "run" "-p" "cargo-makepad" "--release" "--message-format=json" "--"
                "android"  "--no-icon" "--small-fonts" "run" "-p" self.name "--release" "--message-format=json"
            ],
        )
    }
}

let RunStudioRelease = RunItem{
    on_run: fn(){
        hub.run(
            {"STUDIO": hub.studio_ip},
            "cargo", 
            ["run" "-p" self.name "--release" "--message-format=json" "--" "--message-format=json" "--stdin-loop"],
        )
    }
}

hub.set_run_items([
    RunStudioRelease{name: "makepad-example-browser"}
    RunStudioRelease{name: "makepad-example-automate"}
    RunStudioRelease{name: "makepad-example-charts"}
    RunStudioRelease{name: "makepad-example-pdf"}
   //RunStudioRelease{name: "makepad-example-gltf"}
    RunStudioRelease{name: "makepad-example-map"}
    RunStudioRelease{name: "makepad-example-todo"}
    RunStudioRelease{name: "makepad-example-physics"}
    RunStudioRelease{name: "makepad-example-splash"}
    RunStudioRelease{name: "makepad-example-splat"}
    RunStudioRelease{name: "makepad-studio"}
    RunQuest{name: "makepad-example-xr"}
    RunAndroid{name: "makepad-example-gltf"} 
])
